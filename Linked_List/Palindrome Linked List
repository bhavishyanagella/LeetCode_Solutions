# Definition for singly-linked list.
# class ListNode(object):
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution(object):
    def reverse(self,node):
        prev = None
        curr = node
        while curr:
            nextNode = curr.next
            curr.next = prev 
            prev = curr
            curr = nextNode
        return prev
    def isPalindrome(self, head):
        slow = head
        fast = head
        while fast is not None and fast.next is not None:
            slow = slow.next
            fast = fast.next.next

        secondhead = self.reverse(slow)
        temp1 = head
        temp2 = secondhead
        while temp2:
            if temp1.val != temp2.val:
                return False
            temp1 = temp1.next
            temp2 = temp2.next
        
        self.reverse(secondhead)
        return True
        
        
