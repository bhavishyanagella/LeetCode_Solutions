# Definition for singly-linked list.
# class ListNode(object):
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution(object):
    def addTwoNumbers(self, l1, l2):
        dumy = ListNode()
        temp = dumy

        carry = 0
        while (l1 is not None or l2 is not None) or carry:
            sum_val = 0
            if l1 is not None:
                sum_val += l1.val
                l1 = l1.next
            if l2 is not None:
                sum_val += l2.val
                l2 = l2.next
            
            sum_val += carry % 10
            carry = sum_val // 10
            node = ListNode(sum_val % 10)
            temp.next = node
            temp = temp.next
        
        return dumy.next

        
