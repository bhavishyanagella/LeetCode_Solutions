class Solution(object):
    def possible_days(self,bloomDay,day,m,k):
        count = 0
        no_of_bouquets = 0
        n = len(bloomDay)

        for i in bloomDay:
            if i <= day:
                count += 1
                if count == k:
                    no_of_bouquets += 1
                    count = 0     
            else:
                count = 0
        
        if no_of_bouquets >= m:
            return True
        else:
            return False
        
    def minDays(self, bloomDay, m, k):
        n = len(bloomDay)
        if n < m*k:
            return -1
        
        ans = -1
        low = min(bloomDay)
        high  = max(bloomDay)

        while low <= high:
            mid = (low + high) // 2

            if self.possible_days(bloomDay,mid,m,k) == True:
                ans = mid
                high = mid - 1
            else:
                low = mid + 1
        
        return ans
        
