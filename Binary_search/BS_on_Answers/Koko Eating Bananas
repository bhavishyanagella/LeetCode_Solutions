class Solution(object):
    def calculateTotalHours(self,piles,speed):
        totalH = 0
        for banana in piles:
            totalH += (banana + speed - 1) // speed
        return totalH

    def minEatingSpeed(self, piles, h):
        maxPile = max(piles)
        low , high = 1, maxPile
        ans = maxPile

        while low <= high:
            mid = (low + high )//2
            totalH = self.calculateTotalHours(piles,mid)

            if totalH <= h:
                ans = mid
                high = mid - 1
            else:
                low = mid + 1
        
        return ans

        
