class Solution(object):
    def lower_bound(self,nums,target):
        n = len(nums)
        low = 0
        high = n-1
        ans = n

        while low <= high:
            mid = (low + high) //2
            if nums[mid] >= target:
                ans = mid
                high = mid - 1
            else:
                low = mid + 1
        return ans

    def upper_bound(self,nums,target):
        n = len(nums)
        low = 0
        high = n-1
        ans = n

        while low <= high:
            mid = (low + high) //2
            if nums[mid] > target:
                ans = mid
                high = mid - 1
            else:
                low = mid + 1
        return ans

    def searchRange(self, nums, target):
        n = len(nums)
        lb = self.lower_bound(nums,target)

        if (lb == n or nums[lb] != target ):
            return [-1,-1]
        return [lb , self.upper_bound(nums,target)-1]        
                
