class Solution(object):
    def divisor_num(self,nums,val):
        n = len(nums)
        res = 0
        for i in nums:
            res += ceil(float(i)/val)
    
        return res

    def smallestDivisor(self, nums, threshold):
        
        low = 1
        high = max(nums)
        while low <= high:
            mid = (low + high) // 2
            if self.divisor_num(nums,mid) <= threshold:
                high = mid - 1
            else:
                low = mid + 1

        return low
        
