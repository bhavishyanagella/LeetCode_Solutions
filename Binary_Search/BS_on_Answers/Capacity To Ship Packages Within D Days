class Solution(object):
    def required_days(self,weights,capacity):
        days = 1
        load = 0
        for i in weights:
            if load + i > capacity:
                days = days + 1
                load = i
            else:
                load += i
        return days
    def shipWithinDays(self, weights, days):
        low = max(weights)
        high = sum(weights)

        while low <= high:
            mid = (low + high) // 2
            num_days = self.required_days(weights,mid)

            if num_days <= days:
                high = mid - 1
            else:
                low = mid + 1

        return low
        
