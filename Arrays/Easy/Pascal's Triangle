class Solution(object):
    def generaterow(self,r,c):
        n=r-1
        k=c-1
        result=1

        for i in range(k):
            result *= (n-i)
            result //= (i+1)
        return result

    def generate(self, numRows):
        triangle=[]

        for r in range(1,numRows+1):
            row=[]
            for c in range(1,r+1):

                row.append(self.generaterow(r,c))

            triangle.append(row)

        return triangle


        
        
