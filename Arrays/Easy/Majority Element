class Solution(object):
    def majorityElement(self, nums):
        n=len(nums)

        cnt=0
        ele=0

        for num in nums:
            if cnt==0:
                cnt+=1
                ele=num
            elif ele== num:
                cnt+=1
            else:
                cnt-=1

        cnt1=nums.count(ele)

        if cnt1 > n//2:
            return ele
